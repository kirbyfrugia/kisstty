.ifndef CONFIG_INC
CONFIG_INC = 1

.global cfg_init
.global cfg_activate
.global cfg_tick
.global cfg_config_flag
.global cfg_saved_config

CONFIG_FLAG_EDITING  = %00000000
CONFIG_FLAG_CANCELED = %10000000
CONFIG_FLAG_ACCEPTED = %11000000

.linecont +

.struct Menu
  scr_pos_ptr          .word
  header_ptr           .word
  items_values_ptr     .word
  items_labels_ptr     .word
  num_items            .byte
  border_width         .byte
  selected_index       .byte
.endstruct

.struct Config
  protocol    .byte
  mode        .byte
  baud        .byte
  data_bits   .byte
  stop_bits   .byte
  parity      .byte
  cts         .byte
  dsr         .byte
  crx         .byte
  dtr         .byte
  rets        .byte
  xmt         .byte
  translation .byte
  line_feed   .byte
.endstruct

.struct Preset
  scr_pos_ptr .word
  label_ptr   .word
  config_ptr  .word
.endstruct

.macro make_menu menu, header, _items_values, _items_labels, n_items, b_width, scr_pos_offset
  lda #<scr_pos_offset
  clc
  adc SCR_PTR_LO
  sta menu+Menu::scr_pos_ptr
  lda #>scr_pos_offset
  adc SCR_PTR_HI
  sta menu+Menu::scr_pos_ptr+1

  lda #<header
  sta menu+Menu::header_ptr
  lda #>header
  sta menu+Menu::header_ptr+1

  lda #n_items
  sta menu+Menu::num_items
  lda #b_width
  sta menu+Menu::border_width

  lda #<_items_values
  sta menu+Menu::items_values_ptr
  lda #>_items_values
  sta menu+Menu::items_values_ptr+1

  lda #<_items_labels
  sta menu+Menu::items_labels_ptr
  lda #>_items_labels
  sta menu+Menu::items_labels_ptr+1

.endmacro

.macro draw_menu_border menu
  lda #<menu
  sta cfg_ptr_lo
  lda #>menu
  sta cfg_ptr_hi
  jsr int_draw_menu_border
.endmacro

.macro refresh_menu menu, _init_value
  lda #<menu
  sta cfg_ptr_lo
  lda #>menu
  sta cfg_ptr_hi
  lda _init_value
  sta menu_item_value

  jsr int_select_menu_item_by_value
  jsr int_draw_menu_items
  jsr int_highlight_selected_menu_item
.endmacro

.macro make_config  config, _protocol, _mode, _baud, _data_bits, \
                   _stop_bits, _parity, _cts, _dsr, _dtr, _rets
  lda #_protocol
  sta config+Config::protocol
  lda #_mode
  sta config+Config::mode
  lda #_baud
  sta config+Config::baud
  lda #_data_bits
  sta config+Config::data_bits
  lda #_stop_bits
  sta config+Config::stop_bits
  lda #_parity
  sta config+Config::parity
  lda #_cts
  sta config+Config::cts
  lda #_dsr
  sta config+Config::dsr
  lda #_dtr
  sta config+Config::dtr
  lda #_rets
  sta config+Config::rets
  ; TODO: maybe make the rest of these options
  lda #RS232_TRANSLATION::NONE
  sta config+Config::translation
  lda #RS232_LINE_FEED::NO_APPEND_LF
  sta config+Config::line_feed
  lda #RS232_CRX::OFF
  sta config+Config::crx
  lda #RS232_XMT::NO_CHANGE
  sta config+Config::xmt
.endmacro

.macro make_preset preset, config, _label, scr_pos_offset
  lda #<scr_pos_offset
  clc
  adc SCR_PTR_LO
  sta preset+Preset::scr_pos_ptr
  lda #>scr_pos_offset
  adc SCR_PTR_HI
  sta preset+Preset::scr_pos_ptr+1

  lda #<_label
  sta preset+Preset::label_ptr
  lda #>_label
  sta preset+Preset::label_ptr+1

  lda #<config
  sta preset+Preset::config_ptr
  lda #>config
  sta preset+Preset::config_ptr+1
.endmacro

.macro draw_preset preset
  lda #<preset
  sta cfg_ptr_lo
  lda #>preset
  sta cfg_ptr_hi
  jsr int_draw_preset
.endmacro

.macro handle_menu_next _menu
  lda #<_menu
  sta cfg_ptr_lo
  lda #>_menu
  sta cfg_ptr_hi
  jsr int_select_next_menu_item
.endmacro

.endif
